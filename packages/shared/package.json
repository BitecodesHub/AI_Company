{
  "name": "@bitecodes/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod schemas and inferred TypeScript types \u2014 the contract between web and api",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts",
    "./schemas": "./src/schemas/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@bitecodes/config": "workspace:*",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}