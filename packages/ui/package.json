{
  "name": "@bitecodes/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React component library \u2014 shadcn/ui based, Bitecodes themed",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/globals.css"
  },
  "scripts": {
