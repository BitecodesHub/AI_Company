{
  "name": "@bitecodes/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema, migrations, RLS policies, and seed scripts",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "0.38.3",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@bitecodes/config": "workspace:*",
    "drizzle-kit": "0.29.1",
    "typescript": "5.6.3",
    "tsx": "4.19.2",
    "@types/pg": "8.11.10",
    "vitest": "2.1.8"
  }
}