{
  "name": "bitecodes",
  "version": "0.1.0",
  "private": true,
  "description": "Bitecodes — Open-source agentic AI platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "setup:check": "node scripts/setup-check.mjs",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "pnpm --filter @bitecodes/db db:generate",
    "db:push": "pnpm --filter @bitecodes/db db:push",
    "db:migrate": "pnpm --filter @bitecodes/db db:migrate",
    "db:seed": "pnpm --filter @bitecodes/db db:seed",
    "db:studio": "pnpm --filter @bitecodes/db db:studio"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.6.3",
    "prettier": "3.4.2",
    "vitest": "2.1.8",
    "@vitest/ui": "2.1.8",
    "@testing-library/react": "16.1.0",
    "@testing-library/jest-dom": "6.6.3"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.27.4"
    }
  }
}
