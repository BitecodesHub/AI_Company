# ─────────────────────────────────────────────────────────────────────────────
# Bitecodes — environment variable reference
# Copy to .env and fill in the values marked REQUIRED before starting.
# Variables marked ENV-ONLY must be set here; they cannot be overridden via UI.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Public base URL of the web app (browser-visible)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL of the NestJS API
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Branding / white-label (browser-visible) ─────────────────────────────────

# Product wordmark, brand primary colour (bare HSL channels: "H S% L%"), and the
# initial theme. Override these to white-label the app for a tenant.
NEXT_PUBLIC_BRAND_NAME=Bitecodes
NEXT_PUBLIC_BRAND_PRIMARY_HSL=221 83% 53%
NEXT_PUBLIC_DEFAULT_THEME=light          # light | dark | system

# ── Database (REQUIRED) ───────────────────────────────────────────────────────

POSTGRES_USER=bitecodes
POSTGRES_PASSWORD=changeme              # REQUIRED — set a strong password
POSTGRES_DB=bitecodes
DATABASE_URL=postgresql://bitecodes:changeme@localhost:5432/bitecodes

# ── Redis (REQUIRED) ─────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ── Auth (REQUIRED, ENV-ONLY) ─────────────────────────────────────────────────

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
AUTH_URL=http://localhost:4000

# ── Secret vault (ENV-ONLY) ───────────────────────────────────────────────────

# 32-byte base64 key for connector credential encryption (libsodium)
# Generate with: node -e "const s=require('crypto');console.log(s.randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_BASE64_KEY

# ── Super-admin (ENV-ONLY) ────────────────────────────────────────────────────

# Comma-separated email addresses of instance super-admins
SUPERADMIN_EMAILS=admin@example.com

# ── Allowed domains ───────────────────────────────────────────────────────────

ALLOWED_DOMAINS=localhost

# ── Enterprise license ────────────────────────────────────────────────────────

# Required to activate /ee features. Leave blank for open-core.
LICENSE_KEY=

# ── Object storage / MinIO ────────────────────────────────────────────────────

MINIO_ROOT_USER=bitecodes
MINIO_ROOT_PASSWORD=changeme            # REQUIRED for MinIO container

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bitecodes
S3_ACCESS_KEY_ID=bitecodes
S3_SECRET_ACCESS_KEY=changeme           # ENV-ONLY
S3_PUBLIC_URL=http://localhost:9000/bitecodes

# ── AI provider gateway ───────────────────────────────────────────────────────
#
# Bitecodes runs entirely on ONE provider. Pick a single path:
#
#   A) OpenRouter (cloud, one key)  — set AI_PROVIDER=openrouter + OPENROUTER_API_KEY
#   B) Ollama (fully local, no key) — set AI_PROVIDER=ollama + run `ollama serve`
#   C) LiteLLM (advanced/optional)  — set AI_PROVIDER=litellm + LITELLM_* below
#
# Every AI feature (agent runs, content, controller, embeddings) flows through
# this one gateway. There is no need to configure ten provider keys.

AI_PROVIDER=openrouter                  # openrouter | ollama | litellm

# Chat model passed verbatim to the provider. Leave blank to use a per-tier default.
#   OpenRouter e.g. anthropic/claude-3.5-sonnet, openai/gpt-4o-mini, meta-llama/llama-3.1-8b-instruct
#   Ollama     e.g. llama3.1, qwen2.5, mistral
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# AI_GATEWAY_MODE: set to "mock" for CI/tests (deterministic stubs, no key/network).
# Leave blank or set to "live" for real provider calls.
AI_GATEWAY_MODE=                        # mock | live

# ── OpenRouter (path A) ───────────────────────────────────────────────────────

OPENROUTER_API_KEY=                     # REQUIRED when AI_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (path B) ───────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434  # `ollama pull <DEFAULT_MODEL>` + the embedding model

# ── LiteLLM (path C, optional/advanced) ───────────────────────────────────────

LITELLM_BASE_URL=http://localhost:4001
LITELLM_MASTER_KEY=sk-dev-master-key    # ENV-ONLY — change in production

# ── Embeddings (knowledge base, memory) ───────────────────────────────────────
#
# EMBEDDING_PROVIDER=none disables retrieval-dependent features cleanly (no crash).
# OpenRouter does not serve embeddings for most models — use ollama or none there.

EMBEDDING_PROVIDER=ollama               # ollama | openrouter | none
EMBEDDING_MODEL=nomic-embed-text        # ollama: nomic-embed-text | openrouter: openai/text-embedding-3-small

# ── Other provider keys (optional — only used in litellm path) ────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Durable execution (Inngest) ───────────────────────────────────────────────

INNGEST_EVENT_KEY=bitecodes-dev
INNGEST_SIGNING_KEY=signkey-dev-bitecodes   # ENV-ONLY
INNGEST_DEV=1                               # Set to 1 for local Inngest dev server

# ── Auth providers — OAuth sign-in ────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=                   # ENV-ONLY

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=                   # ENV-ONLY

# ── Social and tool connector OAuth apps ─────────────────────────────────────

X_CLIENT_ID=
X_CLIENT_SECRET=                        # ENV-ONLY

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=                 # ENV-ONLY

META_APP_ID=
META_APP_SECRET=                        # ENV-ONLY

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=                    # ENV-ONLY

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=                   # ENV-ONLY

# ── Email (Resend) ────────────────────────────────────────────────────────────

RESEND_API_KEY=                         # ENV-ONLY — leave blank to disable email
EMAIL_FROM=noreply@bitecodes.com

# Signed email approve/reject links for human-in-the-loop approvals
APPROVAL_LINK_SECRET=CHANGE_ME          # ENV-ONLY — HMAC secret for approval links
APPROVAL_LINK_TTL_HOURS=72

# Orchestration: routing confidence at/above this auto-dispatches to the chosen
# employee; below it, the route is proposed for human confirmation (a "divert").
ORCHESTRATION_AUTODISPATCH_THRESHOLD=0.85

# Company chat: cap on recursive agent→agent handoff depth within a conversation.
COMPANY_CHAT_MAX_HANDOFF_DEPTH=5

# Memory & learning loop
MEMORY_RETENTION_DAYS=90
MEMORY_LONGTERM_TOPK=5
CONVERSATION_WINDOW_MESSAGES=20

# ── Billing ───────────────────────────────────────────────────────────────────

# Stripe (managed cloud only — not needed for self-host)
STRIPE_SECRET_KEY=                      # ENV-ONLY
STRIPE_WEBHOOK_SECRET=                  # ENV-ONLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Lago (self-host metering engine)
LAGO_API_URL=http://localhost:3003
LAGO_API_KEY=                           # ENV-ONLY

# ── LLM observability (Langfuse) ─────────────────────────────────────────────

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=                    # ENV-ONLY
LANGFUSE_HOST=http://localhost:3001

# ── App observability (OpenTelemetry) ────────────────────────────────────────

OTEL_EXPORTER_OTLP_ENDPOINT=           # Optional — e.g. http://localhost:4318

# ── Inbound webhooks ──────────────────────────────────────────────────────────

WEBHOOK_SIGNING_SECRET=CHANGE_ME        # ENV-ONLY
